<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PizzaTime" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/active</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->


    </style>
    <style name="Theme.PizzaTime.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.PizzaTime.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="colorPrimary">@color/white</item>
    </style>
    <style name="Theme.PizzaTime.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <style name="Theme.PizzaTime.TypeSelectorButton" parent="Widget.AppCompat.Button">
        <!--<item name="android:backgroundTint">@color/active_20</item>-->
        <item name="colorButtonNormal">@color/active_20</item>
        <item name="android:textColor">@color/active</item>
        <item name="strokeWidth">0dp</item>
        <item name="strokeColor">@color/active_20</item>
        <item name="fontFamily">@font/roboto</item>
        <item name="android:shape">rectangle</item>
        <item name="android:radius">100dp</item>
    </style>
</resources>